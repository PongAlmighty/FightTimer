# Copy this file to .env and fill in your values.
# .env is gitignored — each machine keeps its own copy.

# Port exposed on the host (container always runs on 55011 internally)
HOST_PORT=55011

# Secret key for Flask sessions — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-random-secret
